GridLayoutExemple:

<GridLayoutExemple>:
    cols: 2
    Button:
        text: "A"
    Button:
        text: "B"
    Button:
        text: "C"

<AnchorLayoutExemple>:
    # right, left, center
    anchor_x: "center"
    anchor_y: "top"
    Button:
        text: "Moi"
        size_hint: .1, .1
        
